# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=icecat_integration
DB_USER=icecat
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_SSL=false

# Icecat FrontOffice API Credentials
ICECAT_FO_USERNAME=your_username
ICECAT_FO_PASSWORD=your_password
ICECAT_FO_API_KEY=your_api_key

# Icecat FTP Credentials
ICECAT_FTP_HOST=data.icecat.biz
ICECAT_FTP_USERNAME=your_ftp_username
ICECAT_FTP_PASSWORD=your_ftp_password
ICECAT_FTP_TIMEOUT=30

# Application Settings
BATCH_SIZE=100
REQUEST_TIMEOUT=300
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/icecat/integration.log
